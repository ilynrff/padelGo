generator client {
  provider = "prisma-client-js"
  engineType = "library"
  binaryTargets = ["native", "windows"]
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id        String    @id @default(uuid())
  name      String
  email     String    @unique
  password  String
  role      String    @default("USER") // Using string default pattern for SQLite simple integration instead of Enum which wasn't supported robustly historically without extra generator configs
  bookings  Booking[]
  createdAt DateTime  @default(now())
}

model Court {
  id          String    @id @default(uuid())
  name        String
  location    String
  price       Float
  description String?
  isActive    Boolean   @default(true)
  bookings    Booking[]
  createdAt   DateTime  @default(now())
}

model Booking {
  id            String        @id @default(uuid())
  userId        String
  courtId       String
  date          DateTime      
  timeSlot      String        // e.g., '10:00-11:00'
  status        String        @default("PENDING")
  paymentStatus String        @default("UNPAID")
  user          User          @relation(fields: [userId], references: [id])
  court         Court         @relation(fields: [courtId], references: [id])
  createdAt     DateTime      @default(now())

  // Prevent double booking on same court
  @@unique([courtId, date, timeSlot]) 
}
